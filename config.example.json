{
  "host": "127.0.0.1",
  "port": 8787,
  "runs_dir": "runs",
  "live_frame_interval_seconds": 0.33,
  "live_state_interval_seconds": 1.0,
  "mcp": {
    "command": "py",
    "args": [
      "-3.13",
      "-m",
      "droplogic.mcp.server",
      "--transport",
      "stdio",
      "--allow-real-hardware",
      "--config",
      "config.json"
    ],
    "env": {
      "PYTHONPATH": "../DropLogic",
      "DROPLOGIC_LOG_DIR": "%LOCALAPPDATA%/DropLogic/logs",
      "DROPLOGIC_COCKPIT_MODE": "1",
      "DROPLOGIC_VISUALIZER_HEADLESS": "1",
      "DROPLOGIC_MCP_CONTEXT_DIR": "../droplogic-dashboard/context/boxmini"
    }
  },
  "ai": {
    "enabled": true,
    "ai_config_file": "backend/ai_config.local.json",
    "ai_auth_file": "backend/ai_auth.local.json",
    "max_context_chars": 800000,
    "target_context_chars": 90000,
    "recent_event_target": 120,
    "large_event_chars": 8000,
    "max_tool_output_chars": 12000,
    "ai_context_summary_enabled": true,
    "ai_context_summary_trigger_chars": 300000,
    "ai_context_summary_max_chars": 12000,
    "pinned_context_files": [
      "agent-guide.md",
      "cockpit-mode.md",
      "cartridge.default.json"
    ]
  },
  "speech": {
    "enabled": true,
    "engine": "faster_whisper",
    "model": "large-v3-turbo",
    "device": "auto",
    "compute_type": "int8",
    "language": null,
    "vad_filter": true,
    "beam_size": 5,
    "best_of": 5,
    "temperature": 0,
    "condition_on_previous_text": false,
    "initial_prompt": "DropLogic BoxMini laboratory control. Common words: BoxMini, DropLogic, dashboard, droplet, droplets, reservoir, injection, extraction, cartridge, whole cartridge, whole chip, matrix, electrodes, streamer, visualizer, Brightfield, FAM, coaxial, ring light, exposure, analog gain, stage, X axis, Y axis, Z axis, temperature, melting probes, IVT, TX TL, MCP.",
    "hotwords": "BoxMini DropLogic droplet droplets reservoir injection extraction cartridge whole cartridge whole chip matrix electrodes streamer visualizer Brightfield FAM coaxial ring light exposure analog gain stage temperature melting probes IVT TX TL MCP",
    "max_audio_seconds": 90,
    "max_audio_bytes": 25000000
  }
}
